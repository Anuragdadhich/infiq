# InfiQ Environment Variables
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local or real API keys.

# Database
DATABASE_URL=postgresql://user:password@host:5432/infiq

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI API (choose one)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Email
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=InfiQ <onboarding@resend.dev>

# Google APIs
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_JSON=your_google_service_account_json

# Environment
ENVIRONMENT=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Webhooks
WEBHOOK_SECRET=your_webhook_secret
